						<div class="document-icon">
							<i class="fas fa-file-pdf text-danger"></i>
						</div>
						<div class="document-details">
							<h5 class="document-title">Правилник за оценяване</h5>
							<p class="document-description text-muted">Критерии и процедури за оценяване на учениците</p>
						</div>
					</div>
					<div class="document-action">
						<button class="btn btn-success btn-sm">
							<i class="fas fa-download me-1"></i>
							Преглед и изтегляне
						</button>
					</div>
				</div>

				<!-- Document Row 8 -->
				<div class="document-row animate-on-scroll delay-1" onclick="openDocument('/documents/qualification-plan-2024.pdf')">
