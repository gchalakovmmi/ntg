package hbo

import (
	"github.com/GeorgiChalakov01/ntg/backend/app/pages/base"
)

templ hboComponents() {
	@hero()
	@infoSection()
	@documentsSection()
}

templ hero() {
	<section class="hero-section bg-primary text-white py-5">
		<div class="container">
			<div class="row justify-content-center text-center">
				<div class="col-lg-8">
					<div class="hero-content animate-on-scroll">
						<div class="hero-icon mb-4">
							<i class="fas fa-book fa-4x text-warning"></i>
						</div>
						<h1 class="display-4 fw-bold mb-3">Основни документи за учебната 2024/2025</h1>
						<p class="lead mb-4">
							Всички необходими документи, планове и графици за текущата учебна година
						</p>
						<div class="hero-stats d-flex justify-content-center gap-4 flex-wrap">
							<div class="stat-item">
								<h3 class="text-warning mb-0">15+</h3>
								<small>Документа</small>
							</div>
							<div class="stat-item">
								<h3 class="text-warning mb-0">2024/25</h3>
								<small>Учебна година</small>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
}

templ infoSection() {
	<section class="section bg-light">
		<div class="container">
			<div class="row">
				<div class="col-lg-8 mx-auto">
					<div class="info-card animate-on-scroll">
						<div class="text-center mb-4">
							<i class="fas fa-file-alt fa-3x text-primary mb-3"></i>
							<h2 class="section-title">Информация за секцията</h2>
						</div>
						<div class="info-content">
							<h4 class="text-primary mb-3">Кратко описание</h4>
							<div class="row">
								<div class="col-md-6">
									<ul class="list-unstyled">
										<li class="mb-2">
											<i class="fas fa-check-circle text-success me-2"></i>
											Учебни планове и програми
										</li>
										<li class="mb-2">
											<i class="fas fa-check-circle text-success me-2"></i>
											Годишни работни планове
										</li>
										<li class="mb-2">
											<i class="fas fa-check-circle text-success me-2"></i>
											Правилници и наредби
										</li>
									</ul>
								</div>
								<div class="col-md-6">
									<ul class="list-unstyled">
										<li class="mb-2">
											<i class="fas fa-check-circle text-success me-2"></i>
											Учебно време и графици
										</li>
										<li class="mb-2">
											<i class="fas fa-check-circle text-success me-2"></i>
											Етични кодекси
										</li>
										<li class="mb-2">
											<i class="fas fa-check-circle text-success me-2"></i>
											Дневни режими
										</li>
									</ul>
								</div>
							</div>
							<div class="alert alert-info mt-4" role="alert">
								<i class="fas fa-info-circle me-2"></i>
								Всички документи са актуални за учебната 2024/2025 година и са одобрени от Министерството на образованието и науката.
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
}

templ documentsSection() {
	<section class="section">
		<div class="container">
			<div class="section-title text-center mb-5 animate-on-scroll">
				<h2>Документи</h2>
				<p class="text-muted">Кликнете върху документ за преглед</p>
			</div>
			
			<div class="documents-container">
				<!-- Document Row 1 -->
				<div class="document-row animate-on-scroll" onclick="openDocument('/documents/timetable-2024.pdf')">
					<div class="document-info">
						<div class="document-icon">
							<i class="fas fa-file-pdf text-danger"></i>
						</div>
						<div class="document-details">
							<h5 class="document-title">График учебно време</h5>
							<p class="document-description text-muted">Разпределение на учебните часове за всички специалности</p>
						</div>
					</div>
					<div class="document-action">
						<button class="btn btn-success btn-sm">
							<i class="fas fa-download me-1"></i>
							Преглед и изтегляне
						</button>
					</div>
				</div>

				<!-- Document Row 2 -->
				<div class="document-row animate-on-scroll delay-1" onclick="openDocument('/documents/ethics-code-2024.pdf')">
					<div class="document-info">
						<div class="document-icon">
							<i class="fas fa-file-pdf text-danger"></i>
						</div>
						<div class="document-details">
							<h5 class="document-title">Етичен кодекс на училищната общност на ЧСУ "Питагор"</h5>
							<p class="document-description text-muted">Правила за етично поведение в училищната среда</p>
						</div>
					</div>
					<div class="document-action">
						<button class="btn btn-success btn-sm">
							<i class="fas fa-download me-1"></i>
							Преглед и изтегляне
						</button>
					</div>
				</div>

				<!-- Document Row 3 -->
				<div class="document-row animate-on-scroll delay-2" onclick="openDocument('/documents/daily-schedule-2024.pdf')">
					<div class="document-info">
						<div class="document-icon">
							<i class="fas fa-file-pdf text-danger"></i>
						</div>
						<div class="document-details">
							<h5 class="document-title">Дневен режим</h5>
							<p class="document-description text-muted">Ежедневно разписание на училищните дейности</p>
						</div>
					</div>
					<div class="document-action">
						<button class="btn btn-success btn-sm">
							<i class="fas fa-download me-1"></i>
							Преглед и изтегляне
						</button>
					</div>
				</div>

				<!-- Document Row 4 -->
				<div class="document-row animate-on-scroll delay-3" onclick="openDocument('/documents/annual-plan-2024.pdf')">
					<div class="document-info">
						<div class="document-icon">
							<i class="fas fa-file-pdf text-danger"></i>
						</div>
						<div class="document-details">
							<h5 class="document-title">Годишен план</h5>
							<p class="document-description text-muted">Планиране на училищните дейности за цялата учебна година</p>
						</div>
					</div>
					<div class="document-action">
						<button class="btn btn-success btn-sm">
							<i class="fas fa-download me-1"></i>
							Преглед и изтегляне
						</button>
					</div>
				</div>

				<!-- Document Row 5 -->
				<div class="document-row animate-on-scroll delay-1" onclick="openDocument('/documents/curriculum-plan-2024.pdf')">
					<div class="document-info">
						<div class="document-icon">
							<i class="fas fa-file-pdf text-danger"></i>
						</div>
						<div class="document-details">
							<h5 class="document-title">Учебен план</h5>
							<p class="document-description text-muted">Разпределение на учебните предмети по класове</p>
						</div>
					</div>
					<div class="document-action">
						<button class="btn btn-success btn-sm">
							<i class="fas fa-download me-1"></i>
							Преглед и изтегляне
						</button>
					</div>
				</div>

				<!-- Document Row 6 -->
				<div class="document-row animate-on-scroll delay-2" onclick="openDocument('/documents/school-regulations-2024.pdf')">
					<div class="document-info">
						<div class="document-icon">
							<i class="fas fa-file-pdf text-danger"></i>
						</div>
						<div class="document-details">
							<h5 class="document-title">Правилник за дейността на училището</h5>
							<p class="document-description text-muted">Основни правила и процедури в училищната дейност</p>
						</div>
					</div>
					<div class="document-action">
						<button class="btn btn-success btn-sm">
							<i class="fas fa-download me-1"></i>
							Преглед и изтегляне
						</button>
					</div>
				</div>

				<!-- Document Row 7 -->
				<div class="document-row animate-on-scroll delay-3" onclick="openDocument('/documents/assessment-regulations-2024.pdf')">
